{
  "manifest_version": 3,
  "name": "PDF Clipper",
  "version": "2.0.0",
  "description": "PDFの指定ページをPNGとしてクリップボードにコピー",
  "permissions": [
    "activeTab",
    "scripting",
    "clipboardWrite",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+P",
        "mac": "Alt+Shift+P"
      },
      "description": "PDF Clipperを開く"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["pdf.min.js", "pdf.worker.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
